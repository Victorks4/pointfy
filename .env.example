# Supabase — copie para .env.local e preencha no dashboard do projeto
# Só a URL base (Settings → General → Project URL). NÃO use /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Apenas servidor (seed, criar usuários no admin) — NUNCA expor no client
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Playwright E2E — copie e2e/credentials.env.example para e2e/credentials.env
# E2E_EMAIL=estagiario@empresa.com
# E2E_PASSWORD=est123
# E2E_ADMIN_EMAIL=admin@empresa.com
# E2E_ADMIN_PASSWORD=admin123
# PLAYWRIGHT_BASE_URL=http://localhost:3000
